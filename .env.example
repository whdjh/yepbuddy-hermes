# 이 파일을 .env로 복사한 뒤 갤럭시 노트20의 Termux 안에서 직접 값을 채우십시오.
# 실제 토큰, API 키, chat ID, user ID는 절대 커밋하지 마십시오.

TELEGRAM_BOT_TOKEN=replace_with_botfather_token
OPENAI_API_KEY=replace_with_openai_api_key

# 봇 사용을 허용할 Telegram 숫자 user ID 목록입니다. 쉼표로 구분합니다.
# 비워 두면 런타임 기본값으로 모든 사용자를 거부합니다.
ALLOWED_USER_IDS=

# 나중에 stub이 아닌 실제 role에서 사용할 OpenAI 모델입니다.
OPENAI_MODEL=gpt-5.5

# 절대 경로가 아니면 프로젝트 루트 기준 상대 경로로 처리합니다.
TOPIC_ROUTES_PATH=config/topic_routes.json
DATA_DIR=data

LOG_LEVEL=INFO
REPLY_MAX_CHARS=3500
