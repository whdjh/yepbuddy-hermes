# 이 파일을 .env로 복사한 뒤 안드로이드 서버의 Termux 안에서 직접 값을 채우십시오.
# 실제 Telegram token, Hermes OAuth client secret, OAuth token은 절대 GitHub에 올리지 마십시오.

TELEGRAM_BOT_TOKEN=replace_with_botfather_token

# 봇 사용을 허용할 Telegram 숫자 user ID 목록입니다. 쉼표로 구분합니다.
# 비워 두면 런타임 기본값으로 모든 사용자를 거부합니다.
ALLOWED_USER_IDS=

# Hermes OAuth 설정입니다.
HERMES_AUTH_URL=
HERMES_TOKEN_URL=
HERMES_CLIENT_ID=
HERMES_CLIENT_SECRET=
HERMES_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
HERMES_SCOPE=

# Hermes 대화 API 설정입니다. 실제 Hermes API 문서에 맞춰 조정하십시오.
HERMES_API_BASE_URL=
HERMES_CHAT_PATH=/v1/chat/completions
HERMES_MODEL=hermes

# 절대 경로가 아니면 프로젝트 루트 기준 상대 경로로 처리합니다.
TOPIC_ROUTES_PATH=config/topic_routes.json
DATA_DIR=data

LOG_LEVEL=INFO
REPLY_MAX_CHARS=3500
